---
import { site } from "@jsp/shared/json";
import type { NavItem } from "@jsp/shared/types";
import { filterNavItems, prefixNavPaths } from "@jsp/shared/utils";
import Nav from "@/comps-tw/Nav.astro";
import NavUser from "@/comps-tw/NavUser.astro";

let items: NavItem[] = site.navSide;
items = filterNavItems(items, "ui");
items = prefixNavPaths(items, "/tw");

const curPath = Astro.url.pathname;
---

<div class="offcanvas offcanvas-start" id="sidebar">
  <div class="offcanvas-header">
    <h2>Pixel</h2>
    <button type="button" data-dismiss="offcanvas">×</button>
  </div>

  <div class="offcanvas-body py-4">
    <Nav items={items} curPath={curPath} className={"nav nav-vertical"} />
    <hr />
    <NavUser user={site.user} />
  </div>
</div>
