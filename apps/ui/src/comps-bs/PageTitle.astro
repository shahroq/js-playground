---
import Nav from "./Nav.astro";
const { page } = Astro.props;
---

{
  (page.title || page.breadcrumb) && (
    <div class="d-flex flex-column py-0 mb-3 border-bottom">
      {page.title && <h1 class="h2">{page.title}</h1>}
      {page.breadcrumb.length > 0 && (
        <Nav items={page.breadcrumb} className="breadcrumb" />
      )}
    </div>
  )
}
