{
  "name": "client-nextjs-16",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "drizzle:reset": "rm -rf ./data/*.db",
    "drizzle:migrate": "drizzle-kit migrate",
    "drizzle:push": "drizzle-kit push",
    "drizzle:boot": "bun run drizzle:reset && bun run drizzle:push",
    "drizzle:seed": "bun run ./data/seed.ts"
  },
  "dependencies": {
    "next": "16.2.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
