// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  // output   = "../generated/prisma"
  output   = "../../generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EDITOR
  USER
}

enum Condition {
  NEW
  USED
  LIKE_NEW
}

enum ReviewStatus {
  APPROVED
  PENDING
  REJECTED
}

model User {
  id         Int      @id @default(autoincrement())
  name       String
  email      String   @unique
  password   String?
  role       Role?    @default(USER)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  created_by Int
  updated_by Int

  products Product[]
  reviews  Review[]
  profile  Profile?

  @@map("users")
}

model Profile {
  id     Int    @id @default(autoincrement())
  bio    String
  user   User   @relation(fields: [userId], references: [id])
  userId Int    @unique

  @@map("profiles")
}

model Product {
  id          Int             @id @default(autoincrement())
  name        String
  description String?
  price       Float?
  category    String
  in_stock    Boolean
  created_at  DateTime        @default(now())
  updated_at  DateTime        @updatedAt
  user        User            @relation(fields: [created_by], references: [id])
  created_by  Int
  updated_by  Int
  reviews     Review[]
  categories  Category[]
  summart     ReviewSummary[]

  @@map("products")
}

model Review {
  id         Int          @id @default(autoincrement())
  product    Product      @relation(fields: [product_id], references: [id])
  product_id Int
  content    String
  rating     Int
  status     ReviewStatus @default(PENDING)
  created_at DateTime     @default(now())
  updated_at DateTime     @updatedAt
  user       User         @relation(fields: [created_by], references: [id])
  created_by Int
  updated_by Int

  @@index([product_id])
  @@map("reviews")
}

model ReviewSummary {
  id         Int      @id @default(autoincrement())
  product_id Int      @unique
  product    Product  @relation(fields: [product_id], references: [id])
  content    String
  expires_at DateTime
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  created_by Int
  updated_by Int

  @@index([product_id])
  @@map("review_summary")
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String
  products Product[]

  @@map("caregories")
}
