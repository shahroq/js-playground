# basics
NODE_ENV=development
BASE_URL=http://localhost
PORT=3001
APP_NAME=Catalog APP
VERSION=1.0.0

# debug
DEBUG_SHOW_THROWN_ERROR=false
DEBUG_SHOW_EXECUTED_SQL=

# logger
LOGGER_STRATEGY=winston
LOGGER_LEVEL=info
LOGGER_MORGAN_ENABLED=true
LOGGER_MORGAN_FORMAT=tiny


# defaults
DEFAULT_USER_ID=1
DEFAULT_USER_ROLE=USER
DEFAULT_PAGINATION_LIMIT=2
DEFAULT_PAGINATION_MAX_LIMIT=5
DEFAULT_REVIEW_STATUS=PENDING

# hashing
HASHING_STRATEGY=bcrypt

# auth
AUTH_STRATEGY=mock
# mock
# AUTH_MOCK_...=...
# jwt
AUTH_JWT_SECRET=trent
AUTH_JWT_EXPIRES_IN=3600
# auth0
# AUTH_AUTH0_DOMAIN=
# AUTH_AUTH0_AUDIENCE=

# envelope (app response)
# ENVELOPE_STRATEGY=plain
ENVELOPE_STRATEGY=jsend
# ENVELOPE_STRATEGY=json-api
# ENVELOPE_INCLUDE_SYSTEM_INFO=true

# validation
# VALIDATION_STRATEGY=express-validator
# VALIDATION_STRATEGY=joi
VALIDATION_STRATEGY=zod


# database
# DATABASE_URL=file:/data.json
DATABASE_URL=file:./data.db
# DATABASE_URL=mysql://USER:PASSWORD@HOST:PORT/DATABASE_DEV

# DATABASE_CLIENT_STRATEGY=memory
# DATABASE_CLIENT_STRATEGY=file
# DATABASE_CLIENT_STRATEGY=lowdb
DATABASE_CLIENT_STRATEGY=prisma

# http-client
HTTP_CLIENT_STRATEGY=axios

# llm-client
LLM_CLIENT_STRATEGY=mock

# external api infos
# 1. jsonplaceholder api
API_JSONPLACEHOLDER_URL=https://jsonplaceholder.typicode.com

# 2. httpbin.org api
API_HTTPBIN_URL=https://httpbin.org
# API_HTTPBIN_KEY=...

# 3. restful-api.dev api
API_RESTFULAPI_URL=https://api.restful-api.dev

# llm api infos
API_CHATGPT_URL=
API_CHATGPT_KEY=


# mailer
MAILER_STRATEGY=console-log
MAILER_PROTOCOL=smtp
MAILER_HOST=sandbox.smtp.mailtrap.io
MAILER_PORT=2525
MAILER_USERNAME=
MAILER_PASSWORD=
MAILER_ADMIN_EMAIL=

MAILTRAP_API_TOKEN=9d7b0a211514cefadb027e53249b398f
