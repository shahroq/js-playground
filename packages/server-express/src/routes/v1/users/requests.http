@baseUrl = http://localhost:3001
@baseUrlModule = {{baseUrl}}/api/v1/users
@id = 1

### register
POST {{baseUrlModule}}/register HTTP/1.1
Content-Type: application/json

{
    "name": "Jane Doe",
    "email": "admin11@email.com",
    "password": "12345",
    "role": "USER"
}

### login
POST {{baseUrlModule}}/login HTTP/1.1
Content-Type: application/json

{
    "email": "admin@email.com",
    "password": "12345"
}


