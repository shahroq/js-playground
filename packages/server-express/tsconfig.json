{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    "sourceMap": true,

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Best practices
    "strict": true,
    "strictPropertyInitialization": false, // me: disable only this one/ for dto use
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,
    "paths": {
      "@/*": ["./src/*"],
      "@root/*": ["./*"],
      "@users/*": ["./src/routes/v1/users/*"],
      "@products/*": ["./src/routes/v1/products/*"],
      "@reviews/*": ["./src/routes/v1/reviews/*"],
      "@posts/*": ["./src/routes/v1/posts/*"]
    }
  },

  "watchOptions": {
    "excludeDirectories": ["**/node_modules", "_build", "temp/*", "_bak/*"]
  }
}
