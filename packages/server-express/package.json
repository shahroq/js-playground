{
  "name": "server",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "//[RUN]": "",
    "start": "bun run index.ts",
    "start:dev": "bun --watch run index.ts",
    "dev-testfile": "bun --watch run ./script.ts",
    "//[Test]": "Test:",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "//[Prisma]": "",
    "prisma:format": "prisma format",
    "prisma:validate": "prisma validate",
    "prisma:reset": "prisma reset",
    "prisma:clean": "rm -rf ./data/prisma-sqlite/migrations && rm -rf ./data/prisma-sqlite/*.db",
    "prisma:migrate:dev": "prisma migrate dev --name init",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:deploy:test": "dotenv -e .env.test.local -- prisma migrate deploy",
    "prisma:boot": "bun run prisma validate && bun run prisma format && bun run prisma:clean && bun run prisma:migrate:dev && bun run prisma:migrate:dev && bun run prisma:migrate:deploy:test",
    "//[Seed]": "",
    "seed": "bun run ./common/seed/seeder.ts",
    "seed-test": "bun run ./common/seed/seeder-test.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/joi": "^17.2.3",
    "@types/lodash": "^4.17.20",
    "@types/supertest": "^6.0.3",
    "dotenv-cli": "^11.0.0",
    "install": "^0.13.0",
    "prisma": "^6.18.0",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@prisma/client": "^6.18.0",
    "@types/fs-extra": "^11.0.4",
    "axios": "^1.13.2",
    "class-transformer": "^0.5.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-validator": "^7.3.0",
    "fs-extra": "^11.3.2",
    "joi": "^18.0.1",
    "lodash": "^4.17.21",
    "lowdb": "^7.0.1",
    "reflect-metadata": "^0.2.2",
    "uuid": "^13.0.0",
    "zod": "^4.1.12"
  }
}
