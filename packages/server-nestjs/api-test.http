@baseUrl = http://localhost:3002
@baseUrlV1 = {{baseUrl}}/api/v2
@productID = 1
@reviewID = 1

### Home
GET {{baseUrl}} HTTP/1.1

### Health check
GET {{baseUrl}}/health HTTP/1.1

###### PRODUCT MODULE
### get products
GET {{baseUrlV1}}/products HTTP/1.1

### get product
GET {{baseUrlV1}}/products/{{ productID }} HTTP/1.1

### create product
POST {{baseUrlV1}}/products HTTP/1.1
Content-Type: application/json

{
    "name": "New Product 1",
    "description": "Lorem ipsum 1",
    "price": 99.99,
    "category": "Home & Bedding",
    "in_stock": false
}

### update product
PUT {{baseUrlV1}}/products/{{ productID }} HTTP/1.1
Content-Type: application/json

{
    "name": "New Product 1b",
    "description": "Lorem ipsum 1b",
    "price": 99.99,
    "category": "Home & Bedding",
    "in_stock": true
}

### delete product
DELETE {{baseUrlV1}}/products/{{ productID }} HTTP/1.1

###### REVIEW MODULE
### get reviews
GET {{baseUrlV1}}/reviews HTTP/1.1

### get review
GET {{baseUrlV1}}/reviews/{{ reviewID }} HTTP/1.1

### create review
POST {{baseUrlV1}}/reviews HTTP/1.1
Content-Type: application/json

{
    "product_id": 35,
    "content": "New Review 1",
    "rating": 3
}

### update review
PUT {{baseUrlV1}}/reviews/{{ reviewID }} HTTP/1.1
Content-Type: application/json

{
    "product_id": 35,
    "content": "New Review 1b",
    "rating": 3
}

### delete review
DELETE {{baseUrlV1}}/reviews/{{reviewID}} HTTP/1.1

