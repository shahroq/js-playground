@baseUrl = http://localhost:3002
@baseUrlModule = {{baseUrl}}/api/v1/products
@id = 1

### get items
GET {{baseUrlModule}} HTTP/1.1

### get item
GET {{baseUrlModule}}/{{ id }} HTTP/1.1

### create item
POST {{baseUrlModule}} HTTP/1.1
Content-Type: application/json

{
    "name": "New Product 1",
    "description": "Lorem ipsum 1",
    "price": 99.99,
    "categories": ["Electronics"],
    "in_stock": false
}

### update item
PATCH {{baseUrlModule}}/{{ id }} HTTP/1.1
Content-Type: application/json

{
    "name": "updated Product 1b",
    "description": "Lorem ipsum 1b",
    "price": 99.99,
    "in_stock": true
}

### delete item
DELETE {{baseUrlModule}}/{{ id }} HTTP/1.1
