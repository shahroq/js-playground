---
import site from "@gpublic/json/site.json";
import type { NavItem } from "@gpublic/types/types";
import { prefixNavPaths, filterNavItems } from "@gpublic/js/utils";

let navSide: NavItem[] = site.navSide;
navSide = filterNavItems(site.navSide, "ui");
navSide = prefixNavPaths(navSide, "/bs");

const pathname = Astro.url.pathname;
---

<ul class="nav nav-pills- flex-column mb-auto">
  {
    navSide.map((item) => (
      <li class="nav-item">
        <a
          href={item.path}
          class={`nav-link ${item.path === pathname ? "active" : ""}	${"path" in item ? "" : "disabled"}`}
        >
          {item.label}
        </a>
        {item.children && (
          <ul>
            {item.children.map((child) => (
              <li class="nav-item">
                <a
                  href={child.path}
                  class={`nav-link ${child.path === pathname ? "active" : ""}	${"path" in child ? "" : "disabled"}`}
                >
                  {child.label}
                </a>
              </li>
            ))}
          </ul>
        )}
      </li>
    ))
  }
</ul>
