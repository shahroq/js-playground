---
import site from "@gpublic/json/site.json";
import { prefixNavPaths, filterNavItems } from "@gpublic/js/utils";

const pathPrefix = "/bs";
const navSide = prefixNavPaths(filterNavItems(site.navSide, "ui"), pathPrefix);

const pathname = Astro.url.pathname;
// const { url: { pathname } } = Astro;

// const renderMenuItem = (item, pathPrefix = "", curPathname = "") => {
//   if (!item || !item.label) return null;
// };
---

<ul class="nav nav-pills- flex-column mb-auto">
  {
    navSide.map((item) => (
      <li class="nav-item">
        <a
          href={item.path}
          class={`nav-link ${item.path === pathname ? "active" : ""}	${"path" in item ? "" : "disabled"}`}
        >
          {item.label}
        </a>
        {item.children && (
          <ul>
            {item.children.map((child) => (
              <li class="nav-item">
                <a
                  href={child.path}
                  class={`nav-link ${child.path === pathname ? "active" : ""}	${"path" in child ? "" : "disabled"}`}
                >
                  {child.label}
                </a>
              </li>
            ))}
          </ul>
        )}
      </li>
    ))
  }
</ul>
