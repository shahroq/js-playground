---
import "@/styles/global-tw.css";
import Header from "@/components-tw/Header.astro";
import Sidebar from "@/components-tw/Sidebar.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>UI: w/ Tailwind 4</title>
  </head>
  <body class="antialiased bg-slate-50">
    {/* HEADER */}
    <header class="header header-sticky- header-dark">
      <Header />
    </header>

    <div class="container-fluid flex lg:gap-4 h-full">
      {/* SIDEBAR */}
      <aside class="w-auto shrink-0">
        <Sidebar />
      </aside>

      {/* MAIN */}
      <main class="flex-1 py-6">
        <div class="wrapper p-6 rounded bg-white shadow-sm">
          <slot />
        </div>
      </main>
    </div>
    <script src="../js/global-tw.js"></script>
  </body>
</html>

<style>
  body {
  }
</style>
