---
import site from "@gpublic/json/site.json";
import { prefixNavPaths, filterNavItems } from "@gpublic/js/utils";

const pathPrefix = "/tw";
const navSide = prefixNavPaths(filterNavItems(site.navSide, "ui"), pathPrefix);

const pathname = Astro.url.pathname;
---

<ul class="nav nav-vertical">
  {
    navSide.map((item) => (
      <li>
        <a
          href={item.path}
          class={`nav-link ${item.path === pathname ? "active" : ""}	${"path" in item ? "" : "disabled"}`}
        >
          {item.label}
        </a>

        {item.children && (
          <ul>
            {item.children.map((child) => (
              <li>
                <a
                  href={child.path}
                  class={`nav-link ${child.path === pathname ? "active" : ""}	${"path" in child ? "" : "disabled"}`}
                >
                  {child.label}
                </a>
              </li>
            ))}
          </ul>
        )}
      </li>
    ))
  }
</ul>
