---
const { props } = Astro;
---

<div class="form-row">
  <label for={props.id} class="form-label">{props.label}</label>

  {
    props.type === "textarea" && (
      <textarea
        class="form-control"
        id={props.id}
        aria-describedby={`${props.id}-help`}
        placeholder={props.placeholder}
      />
    )
  }

  {
    props.type === "input" && (
      <input
        type={props.subtype}
        class="form-control form-input"
        id={props.id}
        aria-describedby={`${props.id}-help`}
        placeholder={props.placeholder}
      />
    )
  }

  {
    props.type === "select" && (
      <select class="form-control form-select" aria-label="">
        <option selected>Open this select menu</option>
        <option value="1">One</option>
        <option value="2">Two</option>
        <option value="3">Three</option>
      </select>
    )
  }

  <div id={`${props.id}-help`} class="form-description">{props.help}</div>
</div>
