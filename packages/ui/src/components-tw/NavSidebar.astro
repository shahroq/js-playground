---
import site from "/data/site.json";
import { prefixNavItems } from "@/helpers";

const pathPrefix = "/tw";
const navItems = prefixNavItems(site.navItems, pathPrefix);

const pathname = Astro.url.pathname;
---

<ul class="nav nav-vertical">
  {
    navItems.map((item) => (
      <li>
        <a
          href={item.href}
          class={`nav-link ${item.href === pathname ? "active" : ""}	${"href" in item ? "" : "disabled"}`}
        >
          {item.title}
        </a>

        {item.children && (
          <ul>
            {item.children.map((child) => (
              <li>
                <a
                  href={child.href}
                  class={`nav-link ${child.href === pathname ? "active" : ""}	${"href" in child ? "" : "disabled"}`}
                >
                  {child.title}
                </a>
              </li>
            ))}
          </ul>
        )}
      </li>
    ))
  }
</ul>
