---
const { breadcrumb } = Astro.props;
---

<nav aria-label="Breadcrumb">
  <ol class="breadcrumb">
    {
      breadcrumb.map((item, index) => (
        <li
          class={`breadcrumb-item ${index + 1 >= breadcrumb.length ? "last" : ""}`}
        >
          {item.href ? (
            <a href={item.href}>{item.title} </a>
          ) : (
            <span aria-current="page">{item.title}</span>
          )}
        </li>
      ))
    }
  </ol>
</nav>
