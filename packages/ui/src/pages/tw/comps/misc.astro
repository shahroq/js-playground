---
import Layout from "@/layouts/LayoutTW.astro";
import PageTitle from "@/comps-tw/PageTitle.astro";
import DummyBox from "@/comps-tw/DummyBox.astro";
import Alert from "@/comps-tw/Alert.astro";

const page = {
  title: "Misc",
  breadcrumb: [{ label: "Home", path: "/tw" }, { label: "Misc" }],
};
---

<Layout>
  <section>
    <PageTitle page={page} />
    <DummyBox>Dummy Box</DummyBox>
    <Alert variant="primary" dismissible={true}>A simple primary alert</Alert>
  </section>
</Layout>
