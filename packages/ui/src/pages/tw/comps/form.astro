---
import Layout from "@/layouts/LayoutTW.astro";
import PageTitle from "@/comps-tw/PageTitle.astro";
import FormControl from "@/comps-tw/FormControl.astro";

const page = {
  title: "Form",
  breadcrumb: [{ label: "Home", path: "/tw" }, { label: "Forms" }],
};
---

<Layout>
  <section>
    <PageTitle page={page} />

    <form class="form needs-validation was-validated-">
      <FormControl
        type="input"
        subtype="email"
        id="email"
        label="Email"
        help="Enter your valid email address"
        placeholder="Enter your valid email address"
      />

      <FormControl type="input" subtype="text" id="username" label="Username" />

      <FormControl type="input" subtype="number" id="age" label="Age" />

      <FormControl
        type="input"
        subtype="password"
        id="password"
        label="Password"
      />

      <FormControl type="textarea" id="about" label="About" />

      <FormControl type="select" id="role" label="Role" options="" />

      <button type="submit" class="btn btn-primary">Submit</button>
    </form>
  </section>
</Layout>
