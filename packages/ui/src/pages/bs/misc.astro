import PageTitle from "@/comps-bs/PageTitle.astro";
import DummyBox from "@/comps-bs/DummyBox.astro";
import Alert from "@/comps-bs/Alert.astro";

const page = {
  title: "Misc",
  breadcrumb: [{ label: "Home", path: "/tw" }, { label: "Misc" }],
