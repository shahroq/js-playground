---
import NavBreadcrumb from "@/components-bs/NavBreadcrumb.astro";
const { page } = Astro.props;
---

<div class="d-flex flex-column py-0 mb-3 border-bottom">
  {page.title && <h1 class="h2">{page.title}</h1>}
  {page.breadcrumb.length > 0 && <NavBreadcrumb breadcrumb={page.breadcrumb} />}
</div>
