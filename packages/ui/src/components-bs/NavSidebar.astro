---
import site from "/data/site.json";
import { prefixNavItems } from "@/helpers";

const pathPrefix = "/bs";
const navItems = prefixNavItems(site.navItems, pathPrefix);
const pathname = Astro.url.pathname;
// const { url: { pathname } } = Astro;

// const renderMenuItem = (item, pathPrefix = "", curPathname = "") => {
//   if (!item || !item.title) return null;
// };
---

<ul class="nav nav-pills- flex-column mb-auto">
  {
    navItems.map((item) => (
      <li class="nav-item">
        <a
          href={item.href}
          class={`nav-link ${item.href === pathname ? "active" : ""}	${"href" in item ? "" : "disabled"}`}
        >
          {item.title}
        </a>
        {item.children && (
          <ul>
            {item.children.map((child) => (
              <li class="nav-item">
                <a
                  href={child.href}
                  class={`nav-link ${child.href === pathname ? "active" : ""}	${"href" in child ? "" : "disabled"}`}
                >
                  {child.title}
                </a>
              </li>
            ))}
          </ul>
        )}
      </li>
    ))
  }
</ul>
